# =============================================================================
# TruthTrace 环境变量配置模板
# =============================================================================
# 用法: cp .env.example .env → 编辑 .env → 启动服务
#
# 快速生产部署 (3步):
#   1. JWT_SECRET_KEY=$(python -c "import secrets; print(secrets.token_urlsafe(64))")
#   2. DB_PASSWORD=<your_secure_db_password>
#   3. docker compose -f docker-compose.yml -f deploy/docker-compose.prod.yml up -d
# =============================================================================

# ---- 应用 ----
APP_NAME=TruthTrace — 平浪散暴
APP_VERSION=3.0.0
DEBUG=false

# ---- 安全 (⚠️ 生产环境必须设置！) ----
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# ---- CORS (前端域名, 逗号分隔) ----
# 生产示例: https://truthtrace.app
# 本地开发留空即可 (自动允许 localhost:5173, localhost:3000)
CORS_ORIGINS=

# ---- 数据库 ----
# PostgreSQL 生产环境 (Docker Compose 自动使用 DB_PASSWORD 环境变量):
#   DATABASE_URL=postgresql+asyncpg://truthtrace:${DB_PASSWORD}@postgres:5432/truthtrace
# PostgreSQL 外部托管 (Render/Supabase/AWS RDS):
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/truthtrace
# SQLite 零依赖开发模式:
DATABASE_URL=sqlite+aiosqlite:///truthtrace_local.db
DB_PASSWORD=truthtrace_dev

# ---- Redis (速率限制 + 缓存 + Celery消息队列) ----
# Docker: redis://redis:6379/0
# 本地: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ---- Celery 异步任务队列 ----
# Docker 生产: redis://redis:6379/1 (broker) + redis://redis:6379/2 (backend)
# 本地开发: 留空则回退同步执行 (无Celery依赖)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Celery Worker 配置 (生产环境)
# CELERY_WORKER_CONCURRENCY=4
# CELERY_TASK_TIME_LIMIT=600
# CELERY_TASK_SOFT_TIME_LIMIT=540

# ---- AI/LLM (可选，启用更强分析) ----
# Claude API: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Google Fact Check API (可选，启用第三方核查交叉验证) ----
# https://developers.google.com/fact-check/tools/api
# GOOGLE_FACT_CHECK_API_KEY=

# ---- 邮件通知 (可选) ----
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@truthtrace.app

# ---- 错误追踪 (可选) ----
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ---- Elasticsearch (可选，全文搜索引擎) ----
# ELASTICSEARCH_URL=http://localhost:9200

# ---- 爬虫配置 ----
# CRAWLER_CONCURRENCY=10
# CRAWLER_TIMEOUT=30
