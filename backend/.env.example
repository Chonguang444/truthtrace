# TruthTrace 后端环境变量模板
# 复制此文件为 .env 并修改值: cp .env.example .env

# ---- 应用 ----
APP_NAME=TruthTrace - 平浪散暴
APP_VERSION=0.1.0
DEBUG=false

# ---- 安全 (生产环境必须设置!) ----
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=请在此填入生成的随机64位密钥

# ---- CORS (前端域名, 逗号分隔) ----
# Vercel: https://your-app.vercel.app
# 本地开发留空即可 (自动允许 localhost:5173)
CORS_ORIGINS=

# ---- 数据库 ----
# PostgreSQL (生产/Render)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/truthtrace

# SQLite (零依赖开发)
# DATABASE_URL=sqlite+aiosqlite:///truthtrace_local.db

# ---- Redis (速率限制 + Celery) ----
REDIS_URL=redis://localhost:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- AI/LLM (可选) ----
# ANTHROPIC_API_KEY=sk-ant-xxx

# ---- 邮件通知 (可选) ----
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ---- 错误追踪 (可选) ----
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ---- Elasticsearch (可选) ----
# ELASTICSEARCH_URL=http://localhost:9200
