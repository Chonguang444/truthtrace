# TruthTrace 后端环境变量模板
# 复制此文件为 .env 并修改值
# cp .env.example .env

APP_NAME=TruthTrace
APP_VERSION=0.1.0
DEBUG=false

# JWT 安全密钥 — 生产环境必须设置!
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=请在此填入生成的随机密钥

# PostgreSQL 数据库 (生产)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/truthtrace
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/truthtrace

# 或 SQLite (开发/零依赖)
# DATABASE_URL=sqlite+aiosqlite:///truthtrace_local.db
# DATABASE_URL_SYNC=sqlite:///truthtrace_local.db

# Redis (速率限制 + Celery)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch (可选 — 增强搜索)
ELASTICSEARCH_URL=http://localhost:9200

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
