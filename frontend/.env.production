# TruthTrace Frontend — Production Environment Variables
# Set these in your deployment dashboard (Vercel/Render/Netlify)
# VITE_API_BASE_URL — Backend API URL (required!)
# Example: https://truthtrace-api.onrender.com
VITE_API_BASE_URL=/api
# VITE_WS_URL — WebSocket URL (auto-detected from API URL if unset). Relative URLs use same origin.
VITE_WS_URL=
