# TruthTrace Frontend — Production Environment Variables
# VITE_API_BASE_URL — Backend API URL (required!)
# Must point to the Render backend, not a relative path!
VITE_API_BASE_URL=https://truthtrace-ga9b.onrender.com
# VITE_WS_URL — WebSocket URL (auto-detected from API URL if unset)
VITE_WS_URL=wss://truthtrace-ga9b.onrender.com
